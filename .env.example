# Klucz TomTom Traffic API. Skopiuj ten plik do .env i ustaw swoj klucz.
TOMTOM_API_KEY=your_tomtom_api_key_here

# Czestotliwosc odpytywania TomTom (sekundy)
POLL_INTERVAL_SECONDS=60

# Sciezka pliku bazy SQLite
DB_PATH=traffic.db

# Groq (LLM) - generacja narracji raportow operacyjnych
GROQ_API_KEY=your_groq_api_key_here
# Domyslnie lekki model - wysokie limity darmowego planu (14.4k req/dobe),
# wystarczajacy do generacji co minute. 70B ma tylko 1k req/dobe (szybko 429).
GROQ_MODEL=llama-3.1-8b-instant
# Ustaw na false, aby wylaczyc LLM i uzywac tylko raportow regulowych
GROQ_ENABLED=true
